                                    <small data-en="Email"
                                           data-tr="E-posta">
                                        Email
                                    </small>
                                    <strong>aysenurkendirciss@gmail.com</strong>
                                </span>
                            </a>

                            <a class="contact-info-item"
                               href="https://github.com/aysenurkendirci"
                               target="_blank"
                               rel="noopener noreferrer">
                                <span class="contact-icon github-icon" aria-hidden="true">
                                    <i class="fa-brands fa-github"></i>
                                </span>
                                <span>
                                    <small data-en="GitHub"
                                           data-tr="GitHub">
                                        GitHub
                                    </small>
                                    <strong data-en="View repositories"
                                            data-tr="Depoları görüntüle">
                                        View repositories
                                    </strong>
                                </span>
                            </a>

                            <a class="contact-info-item"
                               href="https://www.linkedin.com/in/aysenurkendirci"
                               target="_blank"
                               rel="noopener noreferrer">
                                <span class="contact-icon linkedin-icon" aria-hidden="true">
                                    <i class="fa-brands fa-linkedin-in"></i>
                                </span>
                                <span>
                                    <small data-en="LinkedIn"
                                           data-tr="LinkedIn">
                                        LinkedIn
                                    </small>
                                    <strong data-en="Connect with me"
                                            data-tr="Benimle bağlantı kurun">
                                        Connect with me
                                    </strong>
                                </span>
                            </a>
                        </div>
                    </aside>

                    <form class="contact-form"
                          action="https://formspree.io/f/REPLACE_WITH_YOUR_FORMSPREE_ID"
                          method="POST"
                          novalidate
                          aria-describedby="form-help">

                        <fieldset>

                            <legend class="sr-only">
                                <span data-en="Contact Form" data-tr="İletişim Formu">Contact Form</span>
                            </legend>

                            <p id="form-help" class="sr-only">
                                <span data-en="Fill in your details and message to get in touch"
                                      data-tr="Benimle iletişim kurmak için ayrıntılarınızı ve mesajınızı doldurun">
                                    Fill in your details and message to get in touch
                                </span>
                            </p>
                            
                            <div class="form-group">
                                <label for="name"
                                       data-en="Name"
                                       data-tr="Ad Soyad">
                                    Name
                                    <span aria-label="required" title="Required">*</span>
                                </label>
                                <input
                                    type="text"
                                    id="name"
                                    name="name"
                                    placeholder="Your name"
                                    data-placeholder-en="Your name"
                                    data-placeholder-tr="Adınızı yazın"
                                    required
                                    aria-required="true"
                                    aria-label="Your name"
                                >
                            </div>

                            <div class="form-group">
                                <label for="email"
                                       data-en="Email"
                                       data-tr="E-posta">
                                    Email
                                    <span aria-label="required" title="Required">*</span>
                                </label>
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    placeholder="your@email.com"
                                    data-placeholder-en="your@email.com"
                                    data-placeholder-tr="eposta@ornek.com"
                                    required
                                    aria-required="true"
                                    aria-label="Your email address"
                                >
                            </div>

                            <div class="form-group">
                                <label for="message"
                                       data-en="Message"
                                       data-tr="Mesaj">
                                    Message
                                    <span aria-label="required" title="Required">*</span>
                                </label>
                                <textarea
                                    id="message"
                                    name="message"
                                    rows="6"
                                    placeholder="Write your message..."
                                    data-placeholder-en="Write your message..."
                                    data-placeholder-tr="Mesajınızı yazın..."
                                    required
                                    aria-required="true"
                                    aria-label="Your message"
                                ></textarea>
                            </div>
                        </fieldset>

                        <button type="submit" class="btn contact-submit" aria-label="Submit contact form">
                            <span data-en="Send Message"
                                  data-tr="Mesaj Gönder">
                                Send Message
                            </span>
                            <i class="fa-solid fa-paper-plane" aria-hidden="true"></i>
                        </button>
                    </form>
                </div>
            </div>
        </section>
